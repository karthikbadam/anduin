# ---- Dev API key (SQL-seeded; sha256 hash stored in Postgres) ----
ANDUIN_DEV_API_KEY=dev-key-anduin-local-only

# ---- TLE source selection ----
# fixture | replay | celestrak | n2yo | spacetrack
TLE_SOURCE=fixture

# Live-source credentials (LEAVE BLANK FOR DEV)
N2YO_API_KEY=
SPACETRACK_USER=
SPACETRACK_PASSWORD=
# Celestrak is unauthenticated but expects a contact User-Agent
CELESTRAK_USER_AGENT=anduin/0.1 (contact: your-email@example.com)

# ---- Infra endpoints (internal compose hostnames) ----
KAFKA_BOOTSTRAP=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://anduin:anduin-dev@postgres:5432/anduin

# ---- Service behavior ----
CORS_ORIGINS=http://localhost:5180,http://localhost:5173,http://localhost:4173
WATCHLIST_NORAD_IDS=25544,20580,48274
PROPAGATION_TICK_SECONDS=5
BULK_CADENCE_SECONDS=30
TLE_FETCH_INTERVAL_MINUTES=180

# ---- DLQ webhook (optional, Stage 3) ----
DLQ_ALERT_URL=
DLQ_ALERT_RATE_RPM=10

# ---- Stage 1 convenience ----
# Set STUB_PROPAGATE=true to bypass the TODO(me) stubs and emit slow-drifting
# fixed positions, so the pipeline can be demoed before SGP4 is implemented.
STUB_PROPAGATE=true
